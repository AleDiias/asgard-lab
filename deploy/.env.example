# =============================================================================
# Asgard blackbox — exemplo de variáveis para deploy (Docker / VPS)
# =============================================================================
# Copie para deploy/.env e preencha com valores reais (nunca commite .env):
#   cp deploy/.env.example deploy/.env
#
# Instalação inicial (cria deploy/.env na 1.ª corrida se não existir):
#   ./deploy/scripts/prod-install-initial.sh
#
# Subir só o stack:
#   ./deploy/scripts/prod-up.sh
# =============================================================================

# --- PostgreSQL (contentor asgardlab-postgres) ---
POSTGRES_USER=asgard
POSTGRES_PASSWORD=troque_por_senha_forte
POSTGRES_DB=asgard_master

# URL usada pelas APIs **dentro** da rede Docker (hostname do serviço = postgres).
# Utilizador, senha e nome da base devem coincidir com POSTGRES_* acima.
# Se a senha tiver caracteres especiais, codifique-os na URL (RFC 3986).
DATABASE_URL=postgresql://asgard:troque_por_senha_forte@postgres:5432/asgard_master

# --- JWT (obrigatório; o mesmo segredo em api-auth e api-core) ---
JWT_SECRET=troque_por_string_longa_aleatoria
JWT_EXPIRES_IN=7d

# --- URLs públicas (browser, CORS e build do frontend) ---
# URL onde os utilizadores abrem o blackbox (links em e-mails, redirects, etc., api-auth).
PUBLIC_FRONTEND_URL=https://blackbox.exemplo.com

# Obrigatório para api-auth (process.env.FRONTEND_URL). Mantenha igual a PUBLIC_FRONTEND_URL salvo proxy avançado.
FRONTEND_URL=https://blackbox.exemplo.com

# Origens permitidas por CORS (várias separadas por vírgula, sem espaços extras).
CORS_ALLOWED_ORIGINS=https://blackbox.exemplo.com

# Origens que o JavaScript do browser vai usar para chamar as APIs (build-time Vite).
# Podem ser subdomínios ou o mesmo domínio com portas diferentes, conforme o proxy.
# Se toda a API está no mesmo domínio (ex.: `https://api.asgardai.com.br`):
#   PUBLIC_API_AUTH_URL=https://api.asgardai.com.br/api-auth
#   PUBLIC_API_CORE_URL=https://api.asgardai.com.br/api-core
PUBLIC_API_AUTH_URL=https://api.exemplo.com/api-auth
PUBLIC_API_CORE_URL=https://api.exemplo.com/api-core

# --- Portas publicadas no host da VPS ---
HOST_FRONTEND_PORT=80
HOST_API_AUTH_PORT=3001
HOST_API_CORE_PORT=3002

# --- Portas dentro dos contentores (alterar só se necessário) ---
API_AUTH_PORT=3001
API_CORE_PORT=3002

# --- Limites (opcional) ---
JSON_LIMIT=1mb

# --- E-mail / recuperação de senha (api-auth; opcional) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# URL absoluta do logo nos e-mails (opcional).
# EMAIL_LOGO_URL=

# --- Utilizador inicial após seed (api-auth; opcional) ---
# ASGARD_SEED_EMAIL=administrador@asgardai.com.br
# ASGARD_SEED_PASSWORD=
# ASGARD_SEED_NAME=Administrador
