# Copie para deploy/.env e ajuste (nunca commite deploy/.env).
# Instalação inicial na VPS (cria .env na 1.ª corrida se faltar, sobe Docker e seed):
#   ./deploy/scripts/prod-install-initial.sh
# Ou manualmente: cp deploy/env.prod.example deploy/.env

# --- PostgreSQL (credenciais do serviço asgardlab-postgres) ---
POSTGRES_USER=asgard
POSTGRES_PASSWORD=troque_por_senha_forte
POSTGRES_DB=asgard_master

# URL que as APIs usam **dentro** da rede Docker (hostname = nome do serviço: postgres).
# Deve usar o mesmo utilizador/senha/base que acima.
DATABASE_URL=postgresql://asgard:troque_por_senha_forte@postgres:5432/asgard_master

# --- Segurança (obrigatório; o mesmo JWT_SECRET em auth e core) ---
JWT_SECRET=troque_por_string_longa_aleatoria

# --- URLs públicas (browser / CORS) ---
# Onde o utilizador abre o CRM (ex.: https://crm.asgardlab.pt)
PUBLIC_FRONTEND_URL=https://crm.exemplo.com
# Origens permitidas pelo CORS (normalmente a mesma URL do frontend, separadas por vírgula)
CORS_ALLOWED_ORIGINS=https://crm.exemplo.com

# URLs que o **frontend compilado** vai chamar (mesmo host com portas ou subdomínios).
PUBLIC_API_AUTH_URL=https://auth.exemplo.com
PUBLIC_API_CORE_URL=https://core.exemplo.com

# --- Portas no host da VPS (opcional) ---
HOST_FRONTEND_PORT=80
HOST_API_AUTH_PORT=3001
HOST_API_CORE_PORT=3002

# --- Portas internas nos contentores (só altere se souber o que faz) ---
API_AUTH_PORT=3001
API_CORE_PORT=3002

# --- Opcional: e-mail (api-auth) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# --- Opcional: primeiro utilizador seed (api-auth) ---
# ASGARD_SEED_EMAIL=
# ASGARD_SEED_PASSWORD=
# ASGARD_SEED_NAME=
