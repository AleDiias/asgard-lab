# Servidor
PORT=3001
NODE_ENV=development
JSON_LIMIT=1mb
# Lista separada por vírgula. Suporta wildcard (ex.: https://*.asgardai.com.br)
CORS_ALLOWED_ORIGINS=http://localhost:3005,http://127.0.0.1:3005,http://demo.localhost:3005,https://*.asgardai.com.br

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Banco (Master DB)
DATABASE_URL=postgres://asgard:asgard@localhost:5432/asgard_master

# Migrations
# Master: bun run db:generate && bun run db:migrate
# Tenant (schema separado): bun run db:generate:tenant
# As migrations de tenant são aplicadas por banco em runtime (provisionamento), pasta:
# src/infra/database/tenant/migrations

# URL do frontend (para links nos e-mails: redefinir senha / ativar conta)
FRONTEND_URL=http://localhost:3005
# URL absoluta do logo nos e-mails (default: {FRONTEND_URL}/asgard-logo.png — sirva o ficheiro em public/)
# EMAIL_LOGO_URL=https://app.exemplo.com/asgard-logo.png

# SMTP (envio de e-mails)
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=noreply@asgardai.com.br
SMTP_PASS=
SMTP_FROM=noreply@asgardai.com.br

# Seed inicial de Super Admin (alinhado à migration drizzle/0001_seed_administrador_asgard.sql)
ASGARD_SEED_NAME=Administrador
ASGARD_SEED_EMAIL=administrador@asgardai.com.br
ASGARD_SEED_PASSWORD=SenhaAdminInicial123
