{
  "name": "api-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate:tenant": "drizzle-kit generate --config=drizzle.config.tenant.ts",
    "db:migrate:tenant": "drizzle-kit migrate --config=drizzle.config.tenant.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.3.7",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.3"
  }
}
